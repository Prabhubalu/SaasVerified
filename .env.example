# Database
DATABASE_URL="postgresql://user:password@localhost:5432/saasverified?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# SEO Verification
GOOGLE_VERIFICATION="your-google-verification-code"

# Google Analytics 4 (optional — lead form conversion uses gtag generate_lead)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# LeadSquared — hostname only (no /v2 path; code appends /v2/LeadManagement.svc/Lead.Capture)
# Copy exact API host from LeadSquared: Settings → API and Webhooks (e.g. api-in21.leadsquared.com)
LEADSQUARED_HOST="api-in21.leadsquared.com"
# Access key often starts with u$r — Next.js .env treats $ as variable expansion, so the value becomes just "u".
# Fix ONE of these:
# (A) Escape every dollar: LEADSQUARED_ACCESS_KEY="u\$r81540a19f6774ed652cdbea53690e70d"
# (B) Base64 the full key (recommended):
#     1) DELETE or comment out LEADSQUARED_ACCESS_KEY (a leftover "u" line breaks detection).
#     2) node -e 'console.log(Buffer.from("PASTE_FULL_KEY_FROM_UI").toString("base64"))'
#     3) Put the long output on ONE line:
# LEADSQUARED_ACCESS_KEY_B64="long_base64_string_here"
LEADSQUARED_ACCESS_KEY=""
# LEADSQUARED_ACCESS_KEY_B64=""
LEADSQUARED_SECRET_KEY=""
# true = only FirstName, LastName, EmailAddress, Phone, Company (test if mx_* / Source fail in your org)
# LEADSQUARED_SKIP_CUSTOM_FIELDS="true"
# true = log key lengths / attribute count to the server console (no secret values)
# DEBUG_LEADSQUARED="true"
# Optional: Lead Source picklist for /api/contact (default: Contact Website). Must match LeadSquared exactly.
# LEADSQUARED_CONTACT_SOURCE="Contact Website"
# Contact form — schema names from Lead Fields (defaults: mx_Enquiry_Type, Notes). LEADSQUARED_SKIP_CUSTOM_FIELDS does NOT apply to contact.
# LEADSQUARED_CONTACT_ENQUIRY_TYPE_ATTRIBUTE="mx_Enquiry_Type"
# LEADSQUARED_CONTACT_MESSAGE_ATTRIBUTE="Notes"

